{
  "version": 1,
  "author": "Sistema de Iluminação Pública IoT",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-esp32-devkit-v1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-photoresistor-sensor",
      "id": "ldr1",
      "top": -80,
      "left": 230,
      "attrs": { "lux": "500" }
    },
    {
      "type": "wokwi-relay-module",
      "id": "relay1",
      "top": 120,
      "left": 230,
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 120,
      "left": 380,
      "attrs": { "color": "yellow", "label": "Lâmpada" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 145,
      "left": 340,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    ["esp:3V3",   "ldr1:VCC", "red",    []],
    ["esp:GND.1", "ldr1:GND", "black",  []],
    ["ldr1:AO",   "esp:34",   "green",  []],

    ["esp:3V3",   "relay1:VCC", "red",   []],
    ["esp:GND.2", "relay1:GND", "black", []],
    ["esp:26",    "relay1:IN",  "orange",[]],

    ["relay1:COM", "led1:A",   "yellow", []],
    ["led1:C",     "r1:1",     "yellow", []],
    ["r1:2",       "esp:GND.3","black",  []]
  ],
  "dependencies": {}
}
